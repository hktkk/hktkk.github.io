<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>華夏之光 - 青花瓷修復大師</title>
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { margin: 0; padding: 0; background-color: #f5f5f4; }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useRef } = React;

        // --- 1. 題庫資料 [cite: 1] ---
        const ALL_PIECES_DATA = [
            { word: '蘋果', image: '🍎' }, { word: '小鳥', image: '🐦' },
            { word: '小魚', image: '🐟' }, { word: '太陽', image: '☀️' },
            { word: '月亮', image: '🌙' }, { word: '大樹', image: '🌲' },
            { word: '小貓', image: '🐱' }, { word: '小狗', image: '🐶' },
            { word: '花朵', image: '🌸' }, { word: '汽車', image: '🚗' },
            { word: '飛機', image: '✈️' }, { word: '星星', image: '⭐' }
        ];

        const getRandomPieces = () => {
            const shuffled = [...ALL_PIECES_DATA].sort(() => 0.5 - Math.random());
            return shuffled.slice(0, 3).map((item, index) => ({
                id: index,
                word: item.word,
                image: item.image,
                targetId: `target-${index}`,
                isPlaced: false
            }));
        };

        // --- 2. 音訊管理 [cite: 5, 7, 11, 14] ---
        let globalAudioCtx = null;
        const getAudioCtx = () => {
            if (!globalAudioCtx) {
                const AudioContext = window.AudioContext || window.webkitAudioContext;
                if (AudioContext) globalAudioCtx = new AudioContext();
            }
            return globalAudioCtx;
        };

        const unlockAudio = async () => {
            const ctx = getAudioCtx();
            if (ctx && ctx.state === 'suspended') await ctx.resume();
            if (ctx) {
                const osc = ctx.createOscillator();
                const gain = ctx.createGain();
                gain.gain.value = 0;
                osc.connect(gain);
                gain.connect(ctx.destination);
                osc.start();
                osc.stop(ctx.currentTime + 0.1);
            }
        };

        const playDropSound = () => {
            const ctx = getAudioCtx();
            if (!ctx) return;
            const osc = ctx.createOscillator();
            const gain = ctx.createGain();
            osc.type = 'sine';
            osc.frequency.setValueAtTime(800, ctx.currentTime);
            osc.frequency.exponentialRampToValueAtTime(1200, ctx.currentTime + 0.05);
            gain.gain.setValueAtTime(0, ctx.currentTime);
            gain.gain.linearRampToValueAtTime(0.3, ctx.currentTime + 0.02);
            gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.15);
            osc.connect(gain);
            gain.connect(ctx.destination);
            osc.start();
            osc.stop(ctx.currentTime + 0.15);
        };

        const playSuccessSound = () => {
            const ctx = getAudioCtx();
            if (!ctx) return;
            const playTone = (freq, startTime, duration) => {
                const osc = ctx.createOscillator();
                const gain = ctx.createGain();
                osc.type = 'sine';
                osc.frequency.value = freq;
                osc.connect(gain);
                gain.connect(ctx.destination);
                gain.gain.setValueAtTime(0, startTime);
                gain.gain.linearRampToValueAtTime(0.3, startTime + 0.05);
                gain.gain.exponentialRampToValueAtTime(0.01, startTime + duration);
                osc.start(startTime);
                osc.stop(startTime + duration);
            };
            const now = ctx.currentTime;
            playTone(523.25, now, 0.4);
            playTone(659.25, now + 0.1, 0.4);
            playTone(783.99, now + 0.2, 0.4);
            playTone(1046.50, now + 0.3, 0.8);
        };

        // --- 3. 動畫組件 [cite: 19, 23] ---
        const Confetti = () => {
            const colors = ['bg-red-500', 'bg-yellow-400', 'bg-blue-500', 'bg-green-500', 'bg-pink-500'];
            return (
                <div className="absolute inset-0 overflow-hidden pointer-events-none z-50">
                    {[...Array(60)].map((_, i) => (
                        <div key={i} className={`absolute w-3 h-3 md:w-5 md:h-5 ${colors[i % colors.length]} rounded-full opacity-90`}
                             style={{ left: `${Math.random() * 100}%`, top: `-5%`, animation: `fall ${Math.random() * 3 + 2}s linear ${Math.random() * 2}s infinite` }} />
                    ))}
                    <style>{`@keyframes fall { 0% { transform: translateY(-10px) rotate(0deg); opacity: 1; } 100% { transform: translateY(100vh) rotate(360deg); opacity: 0; } }`}</style>
                </div>
            );
        };

        const CutePanda = ({ isVisible }) => (
            <div className={`fixed bottom-10 right-4 md:right-10 transition-transform duration-700 ${isVisible ? 'translate-y-0' : 'translate-y-[200%]'}`}>
                <svg width="150" height="170" viewBox="0 0 200 220" className="w-[120px] md:w-[180px] drop-shadow-xl">
                    <circle cx="40" cy="50" r="25" fill="#1f2937" /><circle cx="160" cy="50" r="25" fill="#1f2937" />
                    <circle cx="100" cy="100" r="70" fill="white" stroke="#1f2937" strokeWidth="6" />
                    <ellipse cx="70" cy="95" rx="20" ry="25" fill="#1f2937" transform="rotate(-15 70 95)" />
                    <ellipse cx="130" cy="95" rx="20" ry="25" fill="#1f2937" transform="rotate(15 130 95)" />
                    <circle cx="75" cy="90" r="6" fill="white" /><circle cx="125" cy="90" r="6" fill="white" />
                    <ellipse cx="100" cy="120" rx="10" ry="6" fill="#1f2937" />
                    <rect x="20" y="150" width="160" height="60" rx="15" fill="#fbbf24" stroke="#b45309" strokeWidth="6" />
                    <text x="100" y="190" fontSize="28" fontWeight="bold" textAnchor="middle" fill="#b45309">大成功！</text>
                </svg>
            </div>
        );

        // --- 4. 遊戲邏輯與渲染 [cite: 26, 39, 40] ---
        function App() {
            const [gameStarted, setGameStarted] = useState(false);
            const [pieces, setPieces] = useState(getRandomPieces());
            const [draggingId, setDraggingId] = useState(null);
            const [dragPos, setDragPos] = useState({ x: 0, y: 0 });
            const [isWin, setIsWin] = useState(false);

            useEffect(() => {
                if (pieces.every(p => p.isPlaced)) {
                    setTimeout(() => { setIsWin(true); playSuccessSound(); }, 300);
                }
            }, [pieces]);

            const handlePointerDown = (e, id) => {
                if (isWin) return;
                e.currentTarget.setPointerCapture(e.pointerId);
                setDraggingId(id);
                setDragPos({ x: e.clientX, y: e.clientY });
            };

            const handlePointerMove = (e) => {
                if (draggingId !== null) setDragPos({ x: e.clientX, y: e.clientY });
            };

            const handlePointerUp = (e, id) => {
                if (draggingId === null) return;
                const targetEl = document.getElementById(`target-${id}`);
                if (targetEl) {
                    const rect = targetEl.getBoundingClientRect();
                    const distance = Math.hypot(e.clientX - (rect.left + rect.width / 2), e.clientY - (rect.top + rect.height / 2));
                    if (distance < rect.width * 1.1) {
                        setPieces(prev => prev.map(p => p.id === id ? { ...p, isPlaced: true } : p));
                        playDropSound();
                    }
                }
                setDraggingId(null);
            };

            if (!gameStarted) {
                return (
                    <div className="w-full h-screen flex flex-col items-center justify-center bg-stone-100">
                        <h1 className="text-4xl font-black text-blue-900 mb-10">青花瓷修復大師</h1>
                        <button onClick={() => { unlockAudio(); setGameStarted(true); }} className="px-12 py-6 bg-yellow-400 font-bold rounded-full animate-bounce">開始遊戲</button>
                    </div>
                );
            }

            return (
                <div className="w-full h-screen flex flex-col overflow-hidden touch-none" onPointerMove={handlePointerMove}>
                    <div className="py-4 text-center bg-white/40 backdrop-blur-md">
                        <h1 className="text-2xl font-black text-blue-900">華夏之光・青花瓷修復大師</h1>
                        <p className="text-blue-700 font-bold">{isWin ? "太棒了！完美修復！" : "拖曳詞語到對應位置"}</p>
                    </div>
                    
                    <div className="flex-1 relative flex items-center justify-center">
                        {/* 簡化的青花瓷 SVG [cite: 46] */}
                        <div className={`relative h-[70vh] aspect-[26/42] bg-white border-4 border-blue-900 rounded-[50%_50%_10%_10%] shadow-2xl ${isWin ? 'scale-105' : ''}`}>
                            <div id="target-0" className="absolute top-[20%] left-1/2 -translate-x-1/2 w-20 h-20 border-2 border-dashed border-blue-300 rounded-full flex items-center justify-center">
                                {pieces[0].isPlaced ? pieces[0].word : pieces[0].image}
                            </div>
                            <div id="target-1" className="absolute top-[50%] left-[20%] w-20 h-20 border-2 border-dashed border-blue-300 rounded-full flex items-center justify-center">
                                {pieces[1].isPlaced ? pieces[1].word : pieces[1].image}
                            </div>
                            <div id="target-2" className="absolute top-[50%] right-[20%] w-20 h-20 border-2 border-dashed border-blue-300 rounded-full flex items-center justify-center">
                                {pieces[2].isPlaced ? pieces[2].word : pieces[2].image}
                            </div>
                        </div>
                    </div>

                    <div className={`h-[15vh] bg-white flex justify-center items-center gap-8 ${isWin ? 'hidden' : ''}`}>
                        {pieces.map(p => !p.isPlaced && (
                            <div key={p.id} onPointerDown={e => handlePointerDown(e, p.id)} onPointerUp={e => handlePointerUp(e, p.id)} className="px-6 py-3 bg-blue-100 border-2 border-blue-800 rounded-full font-bold cursor-grab">
                                {p.word}
                            </div>
                        ))}
                    </div>

                    {draggingId !== null && (
                        <div className="fixed pointer-events-none z-50 px-6 py-3 bg-blue-100 border-2 border-blue-800 rounded-full font-bold" style={{ left: dragPos.x, top: dragPos.y, transform: 'translate(-50%, -50%)' }}>
                            {pieces.find(p => p.id === draggingId).word}
                        </div>
                    )}

                    {isWin && <Confetti />}
                    <CutePanda isVisible={isWin} />
                    {isWin && <button onClick={() => { setIsWin(false); setPieces(getRandomPieces()); }} className="absolute top-4 right-4 p-4 bg-yellow-400 rounded-full font-bold">換一題</button>}
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
